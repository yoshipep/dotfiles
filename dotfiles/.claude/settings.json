{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(cd:*)",
      "Bash(awk:*)",
      "Bash(printf:*)",
      "Bash(gcc:*)",
      "Bash(g++:*)",
      "Bash(diff:*)",
      "Bash(ps:*)",
      "Bash(id:*)",
      "Bash(ip:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(nm:*)",
      "Bash(pkill:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(ss:*)",
      "Bash(test:*)",
      "Bash(time:*)",
      "Bash(uniq:*)",
      "Bash(which:*)",
      "Bash(xxd:*)",
      "Bash(mkdir:*)"
    ]
  }
}
